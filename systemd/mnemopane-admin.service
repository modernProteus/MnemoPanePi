[Unit]
Description=MnemoPane Admin Web UI (gated)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/modernproteus/mnemopane/admin
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -u /home/modernproteus/mnemopane/admin/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target