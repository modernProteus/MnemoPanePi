[Unit]
Description=MnemoPane Network Mode Manager
After=NetworkManager.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/modernproteus/mnemopane
ExecStart=/usr/bin/python3 -u /home/modernproteus/mnemopane/bin/mnemopane_netmode.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target